# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS committer .env sur GitHub

# Ta private key du wallet DEV (pas ton wallet principal !)
PRIVATE_KEY=0xTON_PRIVATE_KEY_ICI

# Adresse qui recevra les fees du protocole (peut être ton wallet dev pour les tests)
FEE_RECIPIENT=0xTON_ADRESSE_ICI

# Adresse de l'arbitre (peut être ton wallet dev pour les tests)
ARBITER_ADDRESS=0xTON_ADRESSE_ICI

# Fee en basis points : 50 = 0.5%
FEE_BPS=50

# RPC URLs
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org
